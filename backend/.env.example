# ============================================================
# BACKEND — Express.js (Render)
# ============================================================

# ── Database ────────────────────────────────────────────────
# Production: your Neon / Supabase / Railway Postgres URL
# Local:      prisma dev generates this automatically
DATABASE_URL="postgresql://user:password@host:5432/socialties?sslmode=require"

# ── Auth ────────────────────────────────────────────────────
# MUST match the AUTH_SECRET / NEXTAUTH_SECRET in the frontend .env
NEXTAUTH_SECRET="your-strong-random-secret-here"

# ── CORS ────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Production: your Vercel URL
# Local:      http://localhost:3000
ALLOWED_ORIGINS="https://your-app.vercel.app,https://socialties.in"

# ── Port ────────────────────────────────────────────────────
# Render injects PORT automatically — only needed for local dev
BACKEND_PORT=4000
