# ============================================================
# FRONTEND — Next.js (Vercel)
# ============================================================

# ── Auth (NextAuth v5) ──────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-strong-random-secret-here"
NEXTAUTH_SECRET="your-strong-random-secret-here"

# Production: your Vercel deployment URL
# Local:      http://localhost:3000
NEXTAUTH_URL="https://your-app.vercel.app"

# ── Backend API ─────────────────────────────────────────────
# Production: your Render backend URL  (e.g. https://socialties-api.onrender.com)
# Local:      http://localhost:4000
NEXT_PUBLIC_API_URL="https://socialties-api.onrender.com"
